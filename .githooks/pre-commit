#!/usr/bin/env bash
set -euo pipefail

# Allow disabling the hook: SKIP_POST_CHECKOUT_HOOK=1 git checkout ...
if [ -n "${SKIP_POST_CHECKOUT_HOOK-}" ]; then
  exit 0
fi

# Ensure we run from the repository root
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || echo ".")"
cd "$REPO_ROOT"

echo "[hooks/pre-commit] Running tests and lint (yarn)..."

if command -v yarn >/dev/null 2>&1; then
  yarn test --silent || { echo "[hooks/pre-commit] Tests failed"; exit 1; }
  yarn lint --silent || { echo "[hooks/pre-commit] Lint failed"; exit 1; }
else
  echo "[hooks/pre-commit] yarn not found; skipping tests/lint"
fi

exit 0
