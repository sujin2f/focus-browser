{
    "name": "focus-browser",
    "version": "0.3.8-beta.2",
    "description": "A lightweight browser without tabs.",
    "license": "MIT",
    "scripts": {
        "dev": "cross-env NODE_ENV=development PORT=1212 concurrently \"yarn run dev:webpack\" \"yarn run dev:main\" \"yarn run dev:electron\"",
        "build": "yarn run clean && concurrently \"yarn run build:main\" \"yarn run build:webpack\"",
        "lint": "eslint -c eslint.config.mjs --ext .ts ./src",
        "clean": "rimraf ./release/app/dist ./release/build",
        "package": "yarn build && yarn run package:-mac && yarn run package:-linux && yarn run package:-win && yarn run rename",
        "package:mac": "yarn build && yarn run package:-mac && yarn run rename",
        "package:linux": "yarn build && yarn run package:-linux && yarn run rename",
        "package:win": "yarn build && yarn run package:-win && yarn run rename",
        "test": "jest --no-cache --forceExit --coverage",
        "analyze": "webpack --profile --json > ./release/stats.json && webpack-bundle-analyzer ./release/stats.json",
        "prepare": "husky",
        "dev:main": "webpack --watch --config webpack.config.mjs --config-name=main",
        "dev:webpack": "webpack serve --config webpack.config.mjs --config-name=renderer",
        "dev:electron": "electronmon ./release/app/dist/main/index.js",
        "build:main": "cross-env NODE_ENV=production webpack --config webpack.config.mjs --config-name=main",
        "build:webpack": "cross-env NODE_ENV=production webpack --config webpack.config.mjs --config-name=renderer",
        "package:-mac": "electron-builder build --publish never --mac",
        "package:-linux": "electron-builder build --publish never --linux",
        "package:-win": "electron-builder build --publish never --win",
        "rename": "node ./release/rename-packages.mjs"
    },
    "author": "Sujin Choi",
    "dependencies": {
        "@ghostery/adblocker-electron": "^2.14.1",
        "@ghostery/adblocker-webextension": "^2.14.1",
        "electron": "^40.6.0",
        "electron-log": "^5.4.3",
        "jwt-decode": "^4.0.0"
    },
    "devDependencies": {
        "@babel/preset-env": "^7.28.3",
        "@eslint/js": "^9.39.0",
        "@tailwindcss/postcss": "^4.1.12",
        "@types/jest": "^30.0.0",
        "@types/jsonwebtoken": "^9.0.10",
        "autoprefixer": "^10.4.21",
        "babel-jest": "^30.1.2",
        "concurrently": "^9.2.1",
        "cross-env": "^10.0.0",
        "css-loader": "^7.1.2",
        "ejs-loader": "^0.5.0",
        "electron-builder": "^26.0.12",
        "electronmon": "^2.0.3",
        "eslint": "^9.39.0",
        "fake-indexeddb": "^6.2.5",
        "html-loader": "^5.1.0",
        "html-webpack-plugin": "^5.6.4",
        "husky": "^9.1.7",
        "jest": "^30.1.3",
        "jest-environment-jsdom": "^30.2.0",
        "jest-fixed-jsdom": "^0.0.11",
        "mini-css-extract-plugin": "^2.10.0",
        "pinst": "^3.0.0",
        "postcss": "^8.5.6",
        "postcss-loader": "^8.2.0",
        "prettier": "^3.6.2",
        "rimraf": "^6.0.1",
        "sass": "^1.91.0",
        "sass-loader": "^16.0.5",
        "style-loader": "^4.0.0",
        "tailwindcss": "^4.1.12",
        "ts-jest": "^29.4.4",
        "ts-loader": "^9.5.4",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1",
        "webpack": "^5.104.1",
        "webpack-bundle-analyzer": "^5.2.0",
        "webpack-cli": "^6.0.1",
        "webpack-dev-server": "^5.2.2"
    },
    "jest": {
        "clearMocks": true,
        "collectCoverage": true,
        "coverageDirectory": "coverage",
        "coverageProvider": "v8",
        "testEnvironment": "jest-fixed-jsdom",
        "moduleNameMapper": {
            "^.+\\.(css)$": "<rootDir>/.jest/mock-css.ts",
            "^@test/(.*)$": "<rootDir>/.jest/$1",
            "^@src/(.*)$": "<rootDir>/src/$1",
            "^@main/(.*)$": "<rootDir>/src/main/$1",
            "^@home/(.*)$": "<rootDir>/src/renderer/src/$1"
        },
        "setupFiles": [
            "fake-indexeddb/auto"
        ],
        "setupFilesAfterEnv": [
            "<rootDir>/.jest/setup.jest.cjs"
        ],
        "testMatch": [
            "<rootDir>/src/**/?(*.)+(spec|test).[tj]s?(x)",
            "<rootDir>/.jest/**/?(*.)+(spec|test).[tj]s?(x)"
        ],
        "extensionsToTreatAsEsm": [
            ".ts"
        ],
        "preset": "ts-jest",
        "transform": {
            "^.+\\.(ts|tsx)?$": "ts-jest",
            "^.+\\.(js|jsx)$": "babel-jest"
        },
        "coveragePathIgnorePatterns": [
            "<rootDir>/.jest/"
        ]
    },
    "prettier": {
        "arrowParens": "always",
        "bracketSpacing": true,
        "endOfLine": "lf",
        "printWidth": 80,
        "proseWrap": "preserve",
        "quoteProps": "as-needed",
        "semi": false,
        "singleQuote": true,
        "tabWidth": 4,
        "trailingComma": "all",
        "useTabs": false
    },
    "babel": {
        "presets": [
            "@babel/preset-env"
        ]
    },
    "build": {
        "productName": "Focus",
        "appId": "com.sujinc.focus",
        "asar": true,
        "files": [
            "dist",
            "build",
            "node_modules",
            "package.json"
        ],
        "mac": {
            "notarize": false,
            "target": {
                "target": "default",
                "arch": [
                    "arm64",
                    "x64"
                ]
            },
            "type": "distribution",
            "hardenedRuntime": true,
            "gatekeeperAssess": false
        },
        "dmg": {
            "contents": [
                {
                    "x": 130,
                    "y": 220
                },
                {
                    "x": 410,
                    "y": 220,
                    "type": "link",
                    "path": "/Applications"
                }
            ]
        },
        "win": {
            "target": [
                "nsis"
            ]
        },
        "linux": {
            "target": {
                "target": "deb",
                "arch": [
                    "arm64",
                    "x64"
                ]
            },
            "category": "Utilities"
        },
        "directories": {
            "app": "release/app",
            "output": "release/build",
            "buildResources": "release/app/build"
        }
    }
}
