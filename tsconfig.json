{
    "compilerOptions": {
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "lib": ["dom", "es2022"],
        "skipLibCheck": true,
        "noImplicitAny": true,
        "sourceMap": true,
        "outDir": "./release/app/dist",
        "baseUrl": "./src",
        "paths": {
            "@src/*": ["./*"],
            "@main/*": ["./main/*"],
            "@controllers/*": ["./main/controllers/*"],
            "@home/*": ["./renderer/*"]
        }
    },
    "include": ["src/**/*"]
}
