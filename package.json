{
    "name": "focus-browser",
    "version": "0.1.3",
    "description": "A lightweight browser without tabs, built with Electron.",
    "license": "MIT",
    "scripts": {
        "start": "cross-env NODE_ENV=development PORT=1212 concurrently \"npm run start:webpack\" \"npm run start:main\" \"npm run start:electron\"",
        "start:main": "webpack --watch --config webpack.config.js --config-name=main",
        "start:webpack": "webpack serve --config webpack.config.js --config-name=renderer",
        "start:electron": "electronmon ./release/app/dist/main/index.js",
        "build": "npm run clean && concurrently \"npm run build:main\" \"npm run build:webpack\"",
        "build:main": "cross-env NODE_ENV=production webpack --config webpack.config.js --config-name=main",
        "build:webpack": "cross-env NODE_ENV=production webpack --config webpack.config.js --config-name=renderer",
        "lint": "eslint -c .eslintrc --ext .ts ./src",
        "clean": "rimraf ./release/app/dist ./release/build",
        "package:alpha": "NODE_PROD=alpha electron-builder build --publish never",
        "package:beta": "NODE_PROD=beta electron-builder build --publish never",
        "test": "jest --no-cache --forceExit --coverage"
    },
    "author": "Sujin Choi",
    "dependencies": {
        "@ghostery/adblocker-electron": "^2.11.6",
        "@ghostery/adblocker-webextension": "^2.11.6",
        "cross-fetch": "^4.1.0",
        "electron": "^38.2.0",
        "electron-log": "^5.4.3"
    },
    "devDependencies": {
        "@babel/preset-env": "^7.28.3",
        "@tailwindcss/postcss": "^4.1.12",
        "@types/jest": "^30.0.0",
        "@typescript-eslint/eslint-plugin": "^8.41.0",
        "@typescript-eslint/parser": "^8.41.0",
        "autoprefixer": "^10.4.21",
        "babel-jest": "^30.1.2",
        "concurrently": "^9.2.1",
        "copy-webpack-plugin": "^13.0.1",
        "cross-env": "^10.0.0",
        "css-loader": "^7.1.2",
        "electron-builder": "^26.0.12",
        "electronmon": "^2.0.3",
        "eslint": "^9.34.0",
        "html-loader": "^5.1.0",
        "html-webpack-plugin": "^5.6.4",
        "jest": "^30.1.3",
        "jest-environment-jsdom": "^30.1.2",
        "postcss": "^8.5.6",
        "postcss-loader": "^8.2.0",
        "prettier": "^3.6.2",
        "rimraf": "^6.0.1",
        "sass": "^1.91.0",
        "sass-loader": "^16.0.5",
        "style-loader": "^4.0.0",
        "tailwindcss": "^4.1.12",
        "ts-jest": "^29.4.4",
        "ts-loader": "^9.5.4",
        "typescript": "^5.9.2",
        "webpack": "^5.101.3",
        "webpack-cli": "^6.0.1",
        "webpack-dev-server": "^5.2.2"
    },
    "build": {
        "productName": "Focus",
        "appId": "com.sujinc.focus",
        "asar": true,
        "files": [
            "dist",
            "node_modules",
            "package.json"
        ],
        "mac": {
            "notarize": false,
            "target": {
                "target": "default",
                "arch": [
                    "arm64",
                    "x64"
                ]
            },
            "type": "distribution",
            "hardenedRuntime": true,
            "gatekeeperAssess": false
        },
        "dmg": {
            "contents": [
                {
                    "x": 130,
                    "y": 220
                },
                {
                    "x": 410,
                    "y": 220,
                    "type": "link",
                    "path": "/Applications"
                }
            ]
        },
        "win": {
            "target": [
                "nsis"
            ]
        },
        "linux": {
            "target": [
                "AppImage"
            ],
            "category": "Utilities"
        },
        "directories": {
            "app": "release/app",
            "output": "release/build"
        }
    }
}
