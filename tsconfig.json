{
    "compilerOptions": {
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "lib": ["dom", "es2022"],
        "skipLibCheck": true,
        "noImplicitAny": true,
        "sourceMap": true,
        "outDir": "./release/app/dist",
        "paths": {
            "@src/*": ["./src/*"],
            "@main/*": ["./src/main/*"],
            "@home/*": ["./src/renderer/*"]
        },
        "isolatedModules": true
    },
    "include": ["src/**/*"]
}
